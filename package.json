{
  "name": "fiber-preflight",
  "private": true,
  "version": "0.1.0",
  "description": "Payment readiness and route diagnostics for the Fiber Network.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm --filter @fiber-preflight/core build && pnpm -r check",
    "test": "pnpm test:fixtures && pnpm test:rpc && pnpm test:web && pnpm test:bundle && pnpm test:api",
    "test:fixtures": "tsx --test tests/fixture-regression.test.ts",
    "test:rpc": "tsx --test tests/rpc-client.test.ts",
    "test:web": "tsx --test tests/web-history.test.ts",
    "test:bundle": "tsx --test tests/support-bundle.test.ts",
    "test:api": "pnpm --filter @fiber-preflight/core build && tsx --test tests/api-contract.test.ts",
    "dev:api": "pnpm --filter @fiber-preflight/api dev",
    "dev:web": "pnpm --filter @fiber-preflight/web dev --host 127.0.0.1",
    "cli": "pnpm --filter @fiber-preflight/cli start",
    "fixture:payable": "pnpm --filter @fiber-preflight/cli start -- check --fixture ../../fixtures/payable-route.json",
    "fixture:mpp": "pnpm --filter @fiber-preflight/cli start -- check --fixture ../../fixtures/mpp-needed.json",
    "fixture:probe": "pnpm --filter @fiber-preflight/cli start -- probe --fixture ../../fixtures/mpp-needed.json",
    "fixture:postmortem": "pnpm --filter @fiber-preflight/cli start -- explain --fixture ../../fixtures/failed-payment.json"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@11.7.0"
}
