{
  "name": "@fiber-preflight/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "fiber-preflight": "./dist/index.js"
  },
  "scripts": {
    "start": "pnpm --filter @fiber-preflight/core build && tsx src/index.ts",
    "live:proof": "pnpm --filter @fiber-preflight/core build && tsx src/live-proof.ts",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fiber-preflight/core": "workspace:*"
  }
}
